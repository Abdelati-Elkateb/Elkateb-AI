{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler", // Best for Vite
    "strict": true,                // This MUST be true to catch your error!
    "jsx": "preserve",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "noImplicitAny": true,
    
    /* Your specific path fixes */
    "paths": {
      "@/*": ["./src/*"]
    },
    "ignoreDeprecations": "5.0" 
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"],
}